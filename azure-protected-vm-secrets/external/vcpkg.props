<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!-- Consume SecretsProvisioningLibDeps-vcpkg.All.x64 NuGet package -->
  <PropertyGroup Label="VcpkgPaths">
    <!-- Version must match packages.global.config -->
    <VcpkgDependenciesVersion>2024.12.16.20260120</VcpkgDependenciesVersion>
    
    <!-- Calculate repo root from this file's location -->
    <VcpkgRepoRoot Condition="'$(EnlistmentRoot)' != ''">$(EnlistmentRoot)</VcpkgRepoRoot>
    <VcpkgRepoRoot Condition="'$(VcpkgRepoRoot)' == ''">$([MSBuild]::GetDirectoryNameOfFileAbove($(MSBuildThisFileDirectory), 'Directory.Build.props'))</VcpkgRepoRoot>
    <VcpkgRepoRoot Condition="'$(VcpkgRepoRoot)' == ''">$(MSBuildThisFileDirectory)..\..\..</VcpkgRepoRoot>
    
    <!-- NuGet package installed location -->
    <VcpkgNuGetRoot>$(VcpkgRepoRoot)\packages\SecretsProvisioningLibDeps-vcpkg.All.x64.$(VcpkgDependenciesVersion)\build\native</VcpkgNuGetRoot>
    <VcpkgNuGetLibRoot>$(VcpkgRepoRoot)\packages\SecretsProvisioningLibDeps-vcpkg.All.x64.$(VcpkgDependenciesVersion)\lib\native\x64</VcpkgNuGetLibRoot>
  </PropertyGroup>
  
  <!-- TPM2-TSS library list -->
  <PropertyGroup>
    <Tpm2TssLibs>tss2-tcti-tbs.lib;tss2-tcti-mssim.lib;tss2-esys.lib;tss2-sys.lib;tss2-mu.lib;tss2-rc.lib;tss2-tctildr.lib</Tpm2TssLibs>
  </PropertyGroup>
  
  <!-- Configuration-specific paths -->
  <PropertyGroup Condition="'$(Configuration)'=='Debug'">
    <VcpkgStaticLibDir>$(VcpkgNuGetLibRoot)\static\debug</VcpkgStaticLibDir>
    <VcpkgDynamicLibDir>$(VcpkgNuGetLibRoot)\dynamic\debug</VcpkgDynamicLibDir>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)'=='Release'">
    <VcpkgStaticLibDir>$(VcpkgNuGetLibRoot)\static</VcpkgStaticLibDir>
    <VcpkgDynamicLibDir>$(VcpkgNuGetLibRoot)\dynamic</VcpkgDynamicLibDir>
  </PropertyGroup>
  
  <!-- Include paths -->
  <PropertyGroup>
    <VcpkgStaticInclude>$(VcpkgNuGetRoot)\include</VcpkgStaticInclude>
    <VcpkgDynamicInclude>$(VcpkgNuGetRoot)\include</VcpkgDynamicInclude>
  </PropertyGroup>
</Project>