<?xml version="1.0"?>
<package>
    <metadata>
        <id>Microsoft.DynamicSecretsProvisioningLibrary</id>
        <version>1.0.3</version>
        <authors>AzSec, ACC</authors>
        <description>Microsoft SSPP DLL - Dynamic library requiring TPM2-TSS DLLs at runtime</description>
        <tags>Native, native</tags>
        <dependencies>
            <!-- Runtime dependency on vcpkg dependencies for TPM2-TSS DLLs -->
            <dependency id="SecretsProvisioningLibDeps-vcpkg.All.x64" version="2024.12.16.20260113" />
        </dependencies>
    </metadata>
     
    <files>
        <!-- Main library -->
        <file src="DynamicSecretsProvisioningLibrary\x64\Release\DynamicSecretsProvisioningLibrary.lib" target="native\lib" />
        <file src="DynamicSecretsProvisioningLibrary\x64\Release\DynamicSecretsProvisioningLibrary.dll" target="native\bin" />
        
        <!-- Headers -->
        <file src="SecretsProvisioningLibrary.h" target="native\include" />
        
        <!-- Documentation -->
        <file src="README.md" target="native" />
    </files>
</package>