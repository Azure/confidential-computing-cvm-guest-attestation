<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>SecretsProvisioningLibDeps-vcpkg.All.x64</id>
    <version>$version$</version>
    <authors>Microsoft</authors>
    <owners>Microsoft</owners>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>TPM2-TSS and OpenSSL libraries from vcpkg for Azure Confidential VM Secrets Provisioning.</description>
    <tags>vcpkg native tpm2 tss openssl crypto security</tags>
    <license type="expression">BSD-2-Clause AND Apache-2.0</license>
  </metadata>
  <files>
    <!-- Headers -->
    <file src="staging\include\**\*" target="build\native\include" />
    
    <!-- Static libs -->
    <file src="staging\lib\x64\static\*.lib" target="lib\native\x64\static" />
    <file src="staging\lib\x64\static\debug\*.lib" target="lib\native\x64\static\debug" />
    
    <!-- Dynamic libs -->
    <file src="staging\lib\x64\dynamic\*.lib" target="lib\native\x64\dynamic" />
    <file src="staging\lib\x64\dynamic\debug\*.lib" target="lib\native\x64\dynamic\debug" />
    
    <!-- Runtime DLLs -->
    <file src="staging\runtimes\win-x64\native\*.dll" target="runtimes\win-x64\native" />
    <file src="staging\runtimes\win-x64\native\debug\*.dll" target="runtimes\win-x64\native\debug" />
    
    <!-- MSBuild targets -->
    <file src="SecretsProvisioningLibDeps-vcpkg.All.x64.targets" target="build\native\SecretsProvisioningLibDeps-vcpkg.All.x64.targets" />
  </files>
</package>
